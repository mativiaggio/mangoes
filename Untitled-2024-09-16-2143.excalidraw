      "locked": false,
      "text": "{\n  // Appwrite Default Fields\n  $id: string;\n  $createdAt: string;\n  $updatedAt: string;\n  $permissions: string[];\n  $databaseId: string;\n  $collectionId: string;\n\n  \"name\": \"string\",                     // Nombre del producto\n  \"description\": \"string\",              // Descripción detallada del producto\n  \"price\": \"float\",                     // Precio del producto\n  \"category\": \"string\",                 // Categoría del producto (ej. Smartphones, Ropa, etc.)\n  \"tags\": [\"array of strings\"],         // Palabras clave para facilitar la búsqueda\n  \"brand\": \"string\",                    // Marca del producto\n  \"stock_quantity\": \"int\",              // Cantidad disponible en inventario\n  \"is_available\": \"boolean\",            // Si el producto está disponible para la compra\n  \"images\": [\"array of strings\"],       // Ids de las imágenes del producto\n  \"attributes\":  String Object,             // Objeto con todos los atributos,\n  \"enterprise_id\": \"ObjectId\",                // Referencia al comercio que ofrece el producto\n  \"status\": \"enum\",                      // Estado del producto (Ej. \"activo\", \"inactivo\", \"en oferta\")\n  \"special_offer\": {                     // Detalles de una oferta especial si aplica\n  \"discount_percentage\": \"float\",     // Descuento en porcentaje\n  \"valid_until\": \"datetime\"           // Fecha límite de la oferta\n  \"enterprise\": Relationship           // Relación con la colección enterprise\n  }\n}\n",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "{\n  // Appwrite Default Fields\n  $id: string;\n  $createdAt: string;\n  $updatedAt: string;\n  $permissions: string[];\n  $databaseId: string;\n  $collectionId: string;\n\n  \"name\": \"string\",                     // Nombre del producto\n  \"description\": \"string\",              // Descripción detallada del producto\n  \"price\": \"float\",                     // Precio del producto\n  \"category\": \"string\",                 // Categoría del producto (ej. Smartphones, Ropa, etc.)\n  \"tags\": [\"array of strings\"],         // Palabras clave para facilitar la búsqueda\n  \"brand\": \"string\",                    // Marca del producto\n  \"stock_quantity\": \"int\",              // Cantidad disponible en inventario\n  \"is_available\": \"boolean\",            // Si el producto está disponible para la compra\n  \"images\": [\"array of strings\"],       // Ids de las imágenes del producto\n  \"attributes\":  String Object,             // Objeto con todos los atributos,\n  \"enterprise_id\": \"ObjectId\",                // Referencia al comercio que ofrece el producto\n  \"status\": \"enum\",                      // Estado del producto (Ej. \"activo\", \"inactivo\", \"en oferta\")\n  \"special_offer\": {                     // Detalles de una oferta especial si aplica\n  \"discount_percentage\": \"float\",     // Descuento en porcentaje\n  \"valid_until\": \"datetime\"           // Fecha límite de la oferta\n  \"enterprise\": Relationship           // Relación con la colección enterprise\n  }\n}\n",
      "autoResize": true,
      "lineHeight": 1.35
    },

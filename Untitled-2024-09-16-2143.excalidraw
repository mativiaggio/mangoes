      "text": "{\n  // Appwrite Default Fields\n  $id: string;\n  $createdAt: string;\n  $updatedAt: string;\n  $permissions: string[];\n  $databaseId: string;\n  $collectionId: string;\n\n  \"name\": \"string\",                  // Nombre de la categoría (Ej. Ropa, Electrónica)\n  \"slug\": \"string\",                  // URL amigable para la categoría (ej. go-shopping.com/categoria/ropa)\n  \"description\": \"string\",           // Descripción opcional de la categoría\n  \"parent_category_id\": \"ObjectId\",  // Referencia a la categoría principal en caso de subcategorías\n  \"is_active\": \"boolean\",            // Estado de la categoría (activa/inactiva)\n}",

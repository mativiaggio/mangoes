      "link": null,
      "locked": false,
      "text": "{\n  // Appwrite Default Fields\n  $id: string;\n  $createdAt: string;\n  $updatedAt: string;\n  $permissions: string[];\n  $databaseId: string;\n  $collectionId: string;\n\n  \"name\": \"string\",                    // Nombre de la marca o comercio\n  \"slug\": \"string\",                    // URL amigable para la tienda (ej. go-shopping.com/nombre-de-la-tienda)\n  \"description\": \"string\",             // Descripción corta de la tienda\n\n\n  \"categories\": [],  // Categorías a las que pertenece (ej. Ropa, Electrónica, etc.)\n\n\n  \"tags\": [\"array of strings\"],        // Palabras clave para mejorar la búsqueda\n  \"logo_url\": \"string\",                // URL del logo de la tienda\n  \"banner_url\": \"string\",                           // URL del banner de la tienda\n  \"membership_status\": \"enum\",           // Estado de la membresía (Ej. \"activa\", \"pendiente\", \"expirada\")\n  \"membership_expiry\": \"datetime\",     // Fecha de expiración de la membresía (si aplica)\n  \"contact_info\": String Object,             // Objeto con todos los contactos.\n  \"social_links\": String Object,             // Objeto con todas las redes sociales,\n  \"business_hours\":  String Object,             // Objeto con todos los horarios,\n  \"store_url\": \"string\",               // URL única de la tienda en la plataforma\n  \"color_primary\": \"string\",         // Color principal del tema (ej. #FF5733)\n  \"color_secondary\": \"string\",       // Color secundario del tema (ej. #FFFFFF)\n  \"status\": \"enum\",                    // Estado de la tienda en la plataforma (Ej. \"activo\", \"inactivo\")\n\n\n  \"products\": [],     // Referencias a los productos de la tienda\n\n}\n",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "{\n  // Appwrite Default Fields\n  $id: string;\n  $createdAt: string;\n  $updatedAt: string;\n  $permissions: string[];\n  $databaseId: string;\n  $collectionId: string;\n\n  \"name\": \"string\",                    // Nombre de la marca o comercio\n  \"slug\": \"string\",                    // URL amigable para la tienda (ej. go-shopping.com/nombre-de-la-tienda)\n  \"description\": \"string\",             // Descripción corta de la tienda\n\n\n  \"categories\": [],  // Categorías a las que pertenece (ej. Ropa, Electrónica, etc.)\n\n\n  \"tags\": [\"array of strings\"],        // Palabras clave para mejorar la búsqueda\n  \"logo_url\": \"string\",                // URL del logo de la tienda\n  \"banner_url\": \"string\",                           // URL del banner de la tienda\n  \"membership_status\": \"enum\",           // Estado de la membresía (Ej. \"activa\", \"pendiente\", \"expirada\")\n  \"membership_expiry\": \"datetime\",     // Fecha de expiración de la membresía (si aplica)\n  \"contact_info\": String Object,             // Objeto con todos los contactos.\n  \"social_links\": String Object,             // Objeto con todas las redes sociales,\n  \"business_hours\":  String Object,             // Objeto con todos los horarios,\n  \"store_url\": \"string\",               // URL única de la tienda en la plataforma\n  \"color_primary\": \"string\",         // Color principal del tema (ej. #FF5733)\n  \"color_secondary\": \"string\",       // Color secundario del tema (ej. #FFFFFF)\n  \"status\": \"enum\",                    // Estado de la tienda en la plataforma (Ej. \"activo\", \"inactivo\")\n\n\n  \"products\": [],     // Referencias a los productos de la tienda\n\n}\n",
      "autoResize": true,
      "lineHeight": 1.35
    },
